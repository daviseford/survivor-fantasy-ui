rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Users: read/write own document only, no self-delete
    match /users/{uid} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
      allow create, update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // Seasons: public read (including unauthenticated), admin-only write
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Competitions: authenticated read, creator/admin update, admin delete
    match /competitions/{competitionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.creator_uid == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.creator_uid);
      allow delete: if isAdmin();
    }

    // Teams: authenticated read, admin-only write
    match /teams/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Team assignments: authenticated read, admin-only write
    match /team_assignments/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Challenges: authenticated read, admin-only write
    match /challenges/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Eliminations: authenticated read, admin-only write
    match /eliminations/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Events: authenticated read, admin-only write
    match /events/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
