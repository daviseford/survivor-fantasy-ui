rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Users: read/write own document only, no self-delete
    match /users/{uid} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
      allow create, update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // Seasons: public read (including unauthenticated), admin-only write
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Competitions: authenticated read, creator/admin update, admin delete
    // Once finished is true, it cannot be reverted to false (one-way transition).
    // Admin SDK bypasses rules for data corrections.
    match /competitions/{competitionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.creator_uid == request.auth.uid;
      allow update: if (isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.creator_uid && request.resource.data.creator_uid == resource.data.creator_uid))
        && !(resource.data.finished == true && !(request.resource.data.finished == true));
      allow delete: if isAdmin();
    }

    // Season-data collections: all share authenticated-read / admin-write. Keep in sync.

    // Teams

    match /teams/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Team assignments
    match /team_assignments/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Challenges
    match /challenges/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Eliminations
    match /eliminations/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Events
    match /events/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
