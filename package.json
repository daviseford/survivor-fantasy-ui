{
  "name": "survivor-fantasy-ui",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint --max-warnings 0",
    "preview": "vite preview",
    "format": "yarn prettier . --write",
    "prepush": "yarn format && yarn lint --fix && yarn tsc",
    "ci": "yarn format && yarn lint && yarn build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "deploy:local": "yarn prepush && yarn build && firebase deploy",
    "up": "yarn upgrade-interactive --latest",
    "e2e": "playwright test",
    "e2e:screenshot": "playwright test screenshot-all --project=chromium-desktop",
    "e2e:setup": "playwright test --project=setup",
    "e2e:audit": "playwright test audit-all --project=setup --project=chromium-desktop --project=chromium-mobile",
    "e2e:ui": "playwright test --ui",
    "new-season": "tsx scripts/new-season.ts",
    "sync-season": "tsx scripts/sync-season.ts",
    "push-all-seasons": "tsx scripts/push-all-seasons.ts",
    "optimize-images": "tsx scripts/optimize-images.ts",
    "tsc:scripts": "tsc -p scripts/tsconfig.json --noEmit",
    "set-admin": "tsx scripts/set-admin-claim.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@mantine/core": "^9.0.0",
    "@mantine/form": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@mantine/modals": "^9.0.0",
    "@mantine/notifications": "^9.0.0",
    "@tabler/icons-react": "^3.41.1",
    "d3-shape": "^3.2.0",
    "firebase": "^12.11.0",
    "lodash-es": "^4.17.21",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mantine/mcp-server": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@types/d3-shape": "^3.1.8",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.7.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react-router-dom": "^7.13.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
