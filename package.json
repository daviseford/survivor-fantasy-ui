{
  "name": "survivor-fantasy-ui",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "yarn prettier . --write",
    "prepush": "yarn format && yarn lint --fix && yarn tsc",
    "ci": "yarn format && yarn lint && yarn build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "deploy:local": "yarn prepush && yarn build && firebase deploy",
    "up": "yarn upgrade-interactive --latest",
    "e2e": "playwright test",
    "e2e:screenshot": "playwright test screenshot-all --project=chromium-desktop",
    "e2e:setup": "playwright test --project=setup",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/charts": "^8.1.0",
    "@mantine/core": "^8.1.0",
    "@mantine/form": "^8.1.0",
    "@mantine/hooks": "^8.1.0",
    "@mantine/modals": "^8.1.0",
    "@mantine/notifications": "^8.1.0",
    "@tabler/icons-react": "^3.2.0",
    "firebase": "^12.11.0",
    "lodash-es": "^4.17.21",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitejs/plugin-react": "^4.5.2",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.38",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "3.2.5",
    "prettier-plugin-organize-imports": "^3.2.4",
    "react-router-dom": "^6.22.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vitest": "^1.5.0"
  }
}
